# =====================================================
# Environment Variables Configuration
# =====================================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration (jika diperlukan)
